APP_NAME="Honey Pay Licenses"
APP_URL=http://localhost:8081
APP_ENV=local

# Porta HTTP no host (compose). Gateway na mesma VPS usa 80/443 — portal usa 8081.
LICENSE_API_HTTP_PORT=8081

# In production: APP_ENV=production, SESSION_SECURE=true, TRUST_PROXY=true (only behind real reverse proxy)
SESSION_SECURE=false
TRUST_PROXY=false

LICENSE_SIGNING_KEY=change-me-to-a-long-random-string

ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=admin123

DB_DRIVER=sqlite
DB_PATH=storage/database.sqlite

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=license_api
DB_USERNAME=root
DB_PASSWORD=

SUPPORT_CONTACT=suporte@localhost

# Checkout webhook (por produto em /admin/webhooks) — aceitar payloads de teste
WEBHOOK_ACCEPT_TEST=false

# Mail (optional — logs metadata only to storage/mail.log, never bodies/tokens)
MAIL_FROM=noreply@localhost
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
